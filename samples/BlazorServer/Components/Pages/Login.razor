@page "/login"

<h1>Sign in</h1>

<form method="post" action="/sign-in">
    <AntiforgeryToken />
    <label>
        Email
        <input type="email" name="email" required />
    </label>
    <p style="font-size: 0.9em; color: #777">
        For demo purposes the email is accepted as-is. A real app calls <code>IPasswordHasher.Verify</code> first.
    </p>
    <button type="submit">Sign in</button>
</form>
